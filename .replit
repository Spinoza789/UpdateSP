modules = ["nodejs-20", "python-3.12", "web", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["wget", "parallel-full"]

[agent]
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0"]
stack = "BEST_EFFORT_FALLBACK"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 21503
externalPort = 3000

[[ports]]
localPort = 21504
externalPort = 3003

[userenv]

[userenv.shared]
BASE_PATH = "/"
VENDOR_SHIPPING_PRICE = "0"
MOCKUP_PORT = "8081"
MOCKUP_BASE_PATH = "/__mockup/"
APP_URL = "https://saltandpeps.co.uk"

[userenv.production]
PUBLIC_URL = "saltandpeps.co.uk"

[userenv.development]
PORT = "5000"
API_PORT = "8080"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/mockup-sandbox: Component Preview Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Product-Landing-Page && bash start.sh"
waitForPort = 5000

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Product-Landing-Page && PORT=8081 BASE_PATH=/__mockup/ pnpm --filter @workspace/mockup-sandbox run dev"
waitForPort = 8081

[workflows.workflow.metadata]
outputType = "console"
isCanvasWorkflow = true

[postMerge]
path = "Product-Landing-Page/scripts/post-merge.sh"
timeoutMs = 120000

[deployment]
deploymentTarget = "autoscale"
build = ["bash", "Product-Landing-Page/scripts/deploy.sh"]
run = ["bash", "Product-Landing-Page/scripts/start-prod.sh"]
